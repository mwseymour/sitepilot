{
  "name": "@sitepilot/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "tsc -b tsconfig.main.json --force",
    "build:preload": "esbuild src/preload/index.ts --bundle --platform=node --format=cjs --sourcemap --external:electron --outfile=dist/preload/index.js",
    "build:renderer": "vite build",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "start": "npm run rebuild:native && npm run build && electron .",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit && tsc -p tsconfig.renderer.json --noEmit"
  },
  "dependencies": {
    "@sitepilot/contracts": "0.1.0",
    "@sitepilot/domain": "0.1.0",
    "@sitepilot/mcp-client": "0.1.0",
    "@sitepilot/plugin-protocol": "0.1.0",
    "@sitepilot/provider-adapters": "0.1.0",
    "@sitepilot/repositories": "0.1.0",
    "@sitepilot/services": "0.1.0",
    "@sitepilot/validation": "0.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^35.2.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.28.0",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.sitepilot.desktop",
    "extraMetadata": {
      "sitepilotProtocolVersion": "1.0.0",
      "sitepilotMinPluginProtocolVersion": "1.0.0"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "out"
    },
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    }
  }
}
