{
  "name": "sitepilot/wordpress-sitepilot",
  "description": "SitePilot WordPress bridge plugin",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.1",
    "wordpress/mcp-adapter": "^0.4.1"
  },
  "autoload": {
    "psr-4": {
      "SitePilot\\": "includes/"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "composer/installers": true
    }
  }
}
